{
  "baseUrl": "https://codeshare.io/5ee6dl",
  "appDomains": ["codeshare.io"],
  "demand": {
    "id": "codeshare-fill-smoke",
    "title": "CodeShare - preenchimento simples",
    "description": "Acessar o CodeShare informado e digitar a palavra teste no editor de texto compartilhado. Não executar outras ações.",
    "acceptanceCriteria": [
      "A página https://codeshare.io/5ee6dl carrega sem erro crítico",
      "O editor de texto compartilhado recebe a palavra teste",
      "Nenhuma ação adicional é executada"
    ],
    "scope": {
      "routes": ["https://codeshare.io/5ee6dl"],
      "features": ["editor compartilhado", "preenchimento de texto"]
    }
  },
  "auth": {
    "kind": "none"
  },
  "llm": {
    "provider": "groq",
    "model": "llama-3.1-8b-instant",
    "apiKeyEnv": "GROQ_PROVIDER",
    "maxSchemaRetries": 2,
    "rateLimitRetries": 4,
    "rateLimitMaxWaitMs": 30000,
    "promptVersion": "v1",
    "temperature": 0,
    "maxTokens": 2048
  },
  "browser": {
    "engine": "chromium",
    "headed": true,
    "viewport": {
      "width": 1366,
      "height": 768
    },
    "locale": "pt-BR",
    "timezone": "America/Sao_Paulo"
  },
  "timeouts": {
    "quiescenceMs": 1200,
    "actionMs": 15000,
    "navigationMs": 45000,
    "scenarioMs": 180000,
    "runMs": 600000
  },
  "runtime": {
    "maxActionsPerTask": 2,
    "elementAvailability": {
      "enabled": true,
      "maxOpenAttempts": 1,
      "allowGlobalEscape": false,
      "allowClickOutside": false,
      "allowedContainers": []
    },
    "tools": {
      "enabled": true
    }
  },
  "recovery": {
    "maxAttemptsPerTask": 2,
    "maxFallbacksPerStep": 1,
    "maxEmergencyActionsPerScenario": 1
  },
  "classifier": {
    "knownNoiseRegexes": [
      "hb-api\\.omnitagjs\\.com",
      "Blocked script execution in 'about:blank'",
      "Failed to load resource: net::ERR_(FAILED|NAME_NOT_RESOLVED)"
    ],
    "knownTrackingDomains": [],
    "treatThirdPartyNetwork5xxAsBug": false
  },
  "privacy": {
    "maskEmails": true,
    "maskJwt": true,
    "maskCookies": true
  },
  "allowedRoutes": [
    "https://codeshare.io/5ee6dl"
  ],
  "output": {
    "runsDir": "./qa-agent-runs",
    "keepVideoOnPass": false,
    "keepTraceOnPass": false
  },
  "agentVersion": "0.1.0"
}
