# LLM (see llm.apiKeyEnv in agent-qa config)
GROQ_PROVIDER=

# Form login auth (when auth.kind = formLogin in config)
MESHA_EMAIL=test@email.com
MESHA_PASSWORD=ExamplePassword123

# Agent QA
AGENT_QA_ALLOW_INSECURE_LLM_TLS=false
AGENT_QA_CONFIG=./agent-qa.config.json

# Pipeline preflight (qa-agent preflight) — populate for local runs
CLICKUP_TOKEN=
CLICKUP_TEAM_ID=XXXXXXXXXXXX
GITHUB_TOKEN=
# Fallbacks for GitHub token (optional if GITHUB_TOKEN is set)
# GH_TOKEN=
# INPUT_GITHUB_TOKEN=

# GitHub Actions PR context — normally injected by CI; optional for local preflight simulation
# GITHUB_EVENT_NAME=pull_request
# GITHUB_EVENT_NAME=pull_request_target
# GITHUB_REF=refs/pull/123/merge
# GITHUB_REF=refs/heads/main
# GITHUB_HEAD_REF=feature/my-branch
# GITHUB_BASE_REF=main
# GITHUB_REPOSITORY=owner/repo
# GITHUB_WORKSPACE=.
# GITHUB_EVENT_PATH=./event.json
# GITHUB_PR_NUMBER=123
