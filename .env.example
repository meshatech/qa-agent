# LLM (see llm.apiKeyEnv in agent-qa config)
GROQ_PROVIDER=gsk_test_key_xxxxxxxxxxxxxxxxxxxxxxxx

# Form login auth (when auth.kind = formLogin in config)
MESHA_EMAIL=test@example.com
MESHA_PASSWORD=ExamplePassword123

# Agent QA
AGENT_QA_ALLOW_INSECURE_LLM_TLS=false
AGENT_QA_CONFIG=./agent-qa.config.json

# Override de baseUrl em CI/preview (aplicado após parse Zod em validate-config e run)
QA_AGENT_BASE_URL=https://pr-42.preview.example.dev
QA_AGENT_PREVIEW_DOMAIN=*.preview.example.dev

# Pipeline preflight (qa-agent preflight) — populate for local runs
CLICKUP_TOKEN=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_TEAM_ID=12345678
GITHUB_TOKEN=ghp_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Fallbacks for GitHub token (optional if GITHUB_TOKEN is set)
GH_TOKEN=
INPUT_GITHUB_TOKEN=

# GitHub Actions PR context — normally injected by CI; optional for local preflight simulation
GITHUB_EVENT_NAME=pull_request
GITHUB_REF=refs/pull/123/merge
GITHUB_HEAD_REF=feature/my-branch
GITHUB_BASE_REF=main
GITHUB_REPOSITORY=owner/repo
GITHUB_WORKSPACE=.
GITHUB_EVENT_PATH=./event.json
GITHUB_PR_NUMBER=123

# Daemon mode — when QA_AGENT_DAEMON=1 the HTTP server starts on this port (default: 3000)
QA_AGENT_DAEMON=1
QA_AGENT_DAEMON_PORT=3000

# Memory store (memory.source = "postgres" or "hybrid")
# Host-side dev (Postgres exposto pelo docker-compose em 5433):
DATABASE_URL=postgresql://agent_qa:agent_qa@localhost:5433/agent_qa_memory
# Dentro do docker-compose o serviço qa-agent já define DATABASE_URL apontando
# para postgres:5432 — não precisa configurar aqui nesse caso.

# Força o modo container no harness Playwright (--no-sandbox). Já definido no
# Dockerfile/compose; só necessário ao rodar fora deles dentro de um container.
QA_AGENT_CONTAINER=1
