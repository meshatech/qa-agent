{
  "baseUrl": "https://meshamail.mesha.com.br/",
  "appDomains": ["meshamail.mesha.com.br"],
  "demand": {
    "id": "meshamail-prod-smoke",
    "title": "MeshaMail produção - smoke autenticado seguro",
    "description": "Após o login feito pelo runtime, validar a área autenticada do MeshaMail, trocar apenas o tema visual da aplicação e depois deslogar. Não criar, excluir, enviar, disparar campanhas, importar contatos ou executar qualquer ação destrutiva.",
    "acceptanceCriteria": [
      "Uma área autenticada fica visível após o login configurado",
      "O menu de conta ou configurações fica visível antes de alterar o tema",
      "O tema visual da aplicação é alterado sem erro crítico",
      "O logout retorna para a tela inicial não autenticada, tela de login, ou URL contendo /login",
      "As telas acessadas carregam sem erro HTTP 5xx",
      "Não há erro crítico de console originado pelo domínio da aplicação",
      "Nenhuma ação destrutiva ou envio real é executado"
    ],
    "scope": {
      "routes": ["https://meshamail.mesha.com.br/"],
      "features": ["login", "tema visual", "logout", "smoke seguro"]
    }
  },
  "auth": {
    "kind": "formLogin",
    "loginUrl": "/",
    "usernameSelector": "#login-email",
    "passwordSelector": "#login-password",
    "submitSelector": "button[type='submit']",
    "usernameEnv": "MESHA_EMAIL",
    "passwordEnv": "MESHA_PASSWORD",
    "successWhen": {
      "urlContains": "meshamail.mesha.com.br"
    },
    "errorTextSelector": "[role='alert'], .alert, .error, .invalid-feedback",
    "maxRetries": 1
  },
  "llm": {
    "provider": "groq",
    "model": "llama-3.1-8b-instant",
    "apiKeyEnv": "GROQ_PROVIDER",
    "maxSchemaRetries": 2,
    "rateLimitRetries": 4,
    "rateLimitMaxWaitMs": 30000,
    "promptVersion": "v1",
    "temperature": 0,
    "maxTokens": 2048
  },
  "browser": {
    "engine": "chromium",
    "headed": true,
    "viewport": {
      "width": 1366,
      "height": 768
    },
    "locale": "pt-BR",
    "timezone": "America/Sao_Paulo"
  },
  "timeouts": {
    "quiescenceMs": 1200,
    "actionMs": 15000,
    "navigationMs": 45000,
    "scenarioMs": 180000,
    "runMs": 600000
  },
  "runtime": {
    "maxActionsPerTask": 2,
    "semanticAliases": {
      "DEAUTHENTICATION": ["Sair", "Logout", "Sign out", "Deslogar", "Encerrar sessão", "Sair da conta"]
    },
    "elementAvailability": {
      "enabled": true,
      "maxOpenAttempts": 1,
      "allowGlobalEscape": false,
      "allowClickOutside": false,
      "allowedContainers": [
        {
          "semanticKey": "account_menu",
          "openAction": {
            "type": "click",
            "target": {
              "strategy": "semantic",
              "semanticKey": "account_menu_trigger",
              "intent": "open account or settings menu",
              "candidates": [
                { "strategy": "role", "role": "button", "name": "Conta e opções" },
                { "strategy": "role", "role": "button", "name": "Account" },
                { "strategy": "text_any", "texts": ["JN"] }
              ]
            },
            "reason": "open configured account or settings menu container"
          }
        }
      ]
    },
    "planning": {
      "executionPlanStrategy": "factory_first"
    },
    "tools": {
      "enabled": true
    }
  },
  "recovery": {
    "maxAttemptsPerTask": 2,
    "maxFallbacksPerStep": 1,
    "maxEmergencyActionsPerScenario": 2
  },
  "classifier": {
    "knownNoiseRegexes": [
      "ResizeObserver loop",
      "favicon\\.ico.*404"
    ],
    "knownTrackingDomains": [
      "google-analytics.com",
      "googletagmanager.com",
      "clarity.ms"
    ],
    "treatThirdPartyNetwork5xxAsBug": false
  },
  "privacy": {
    "maskEmails": true,
    "maskJwt": true,
    "maskCookies": true
  },
  "allowedRoutes": [
    "https://meshamail.mesha.com.br/"
  ],
  "output": {
    "runsDir": "./qa-agent-runs",
    "keepVideoOnPass": false,
    "keepTraceOnPass": false
  },
  "agentVersion": "0.1.0"
}
