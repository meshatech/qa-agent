{
  "name": "agent-qa",
  "version": "0.1.0",
  "description": "Agent QA runtime MVP",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "qa-agent": "dist/main.js"
  },
  "scripts": {
    "postinstall": "node scripts/patch-playwright-ubuntu26.js",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "validate:agent-config": "node scripts/validate-agent-config.mjs",
    "check": "npm run typecheck && npm run lint && npm test && npm run validate:agent-config",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.json\"",
    "qa-agent": "tsx src/main.ts"
  },
  "keywords": [
    "qa",
    "playwright",
    "nestjs",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.47",
    "@langchain/openai": "^1.4.6",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.1",
    "langchain": "^1.4.1",
    "playwright": "^1.61.0-alpha-2026-05-25",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  }
}
